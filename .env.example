# Google OAuth
# Web client credentials from Google Cloud Console
GOOGLE_OAUTH_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-web-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/oauth/google/callback

# Android client (uncomment and replace the web lines above when using mobile OAuth)
# GOOGLE_OAUTH_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=/app/your-android-client-secret.json
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/oauth/google/callback

# SHA-256 fingerprint of your Android signing key (from Google Play Console or keytool)
ANDROID_SHA256_FINGERPRINT=your-android-sha256-fingerprint

# JWT
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=your-secret-key-here

# App behaviour
# Options: production | development
# In development, OTP can be exposed in API responses (controlled by SHOW_DEV_OTP)
APP_ENV=development
EMAIL_VERIFICATION_REQUIRED=true
SHOW_DEV_OTP=true
# SHOW_DEV_OTP only takes effect when APP_ENV=development
EMAIL_OTP_EXPIRE_MINUTES=1
EMAIL_OTP_MAX_ATTEMPTS=5
PRODUCTION_EMAIL_DELIVERY_REQUIRED=true

# SMTP / Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
# Use a Google App Password, not your normal account password
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=your-email@gmail.com

# Database
DB_USER=capstone
DB_PASSWORD=your-db-password
DB_HOST=localhost
# If running inside Docker Compose, change DB_HOST to the service name: capstone-postgresql
DB_PORT=5432
DB_NAME=capstone

# URLs
# Public URL this backend is reachable at (used for file proxy URLs and email links)
BACKEND_PUBLIC_URL=http://localhost:8000

# Deep-link scheme used by the mobile app
FRONTEND_URL=workbyte://app

# MinIO (object storage)
# Host:port only - no scheme, no trailing slash
MINIO_ENDPOINT=localhost:9000
# If running inside Docker Compose, change MINIO_ENDPOINT to the service name: capstone-minio:9000
MINIO_ACCESS_KEY=capstone
MINIO_SECRET_KEY=capstone
MINIO_SECURE=false
# Public base URL that clients use to fetch files from public buckets
# In production, point this to the reverse-proxy path that fronts MinIO (e.g. https://yourdomain.com/storage)
MINIO_PUBLIC_BASE_URL=http://localhost:9000

# Firebase Cloud Messaging (push notifications)
FCM_PROJECT_ID=your-firebase-project-id
# Place the JSON key file in the backend root and mount it into the container
FCM_SERVICE_ACCOUNT_FILE=your-firebase-adminsdk-key.json

# AI / LLM
# GROQ - primary LLM for all AI features, get a key at https://console.groq.com
GROQ_API_KEY=your-groq-api-key

# OpenAI - used as a fallback / for embeddings
OPENAI_API_KEY=your-openai-api-key

# Ollama - optional local LLM, only needed if you want to run models locally
OLLAMA_URL=http://host.docker.internal:11434/api/generate
OLLAMA_TEXT_EMBEDDING=nomic-embed-text
OLLAMA_LLM=gemma3:4b
