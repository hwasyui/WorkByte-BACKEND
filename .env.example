# WorkByte Backend - Environment Variables
# Copy this file to .env and fill in your own values.
# Never commit .env to version control.

# Google OAuth (web client credentials from Google Cloud Console)
GOOGLE_OAUTH_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-web-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/oauth/google/callback

# Android client (uncomment to use mobile OAuth instead)
# GOOGLE_OAUTH_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=/app/your-android-client-secret.json
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/oauth/google/callback

# JWT
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=your-secret-key-here

# Email / OTP
APP_ENV=production
# Options: production | development
# In development, register/resend-verification responses include dev_verification_otp
EMAIL_VERIFICATION_REQUIRED=true
SHOW_DEV_OTP=true
# SHOW_DEV_OTP is only active when APP_ENV=development
EMAIL_OTP_EXPIRE_MINUTES=1
EMAIL_OTP_MAX_ATTEMPTS=5
PRODUCTION_EMAIL_DELIVERY_REQUIRED=true

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
# Use a Google App Password, not your normal account password
SMTP_FROM_EMAIL=your-email@gmail.com

# Database
DB_USER=capstone
DB_PASSWORD=your-db-password
DB_HOST=capstone-postgresql
# Use the Docker service name when running inside Docker Compose
DB_PORT=5432
DB_NAME=capstone

# Frontend URL (used as the base for OAuth redirect deep links)
FRONTEND_URL=workbyte://app

# Supabase (file storage)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Firebase Cloud Messaging (push notifications)
FCM_PROJECT_ID=your-firebase-project-id
FCM_SERVICE_ACCOUNT_FILE=your-firebase-adminsdk-key.json
# Place the JSON file in the backend root and mount it in the Docker container

# GROQ API (primary LLM for all AI features)
# Get your key at: https://console.groq.com
GROQ_API_KEY=your-groq-api-key
